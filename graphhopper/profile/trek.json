{
  "priority": [
    {
      "if": "road_class == TRACK || road_class == PATH",
      "multiply_by": "3.0"
    },
    {
      "if": "road_class == FOOTWAY || road_class == PEDESTRIAN",
      "multiply_by": "2.0"
    },
    {
      "if": "road_class == MOTORWAY || road_class == TRUNK || road_class == PRIMARY || road_class == SECONDARY",
      "multiply_by": "0.05"
    },
    {
      "if": "road_class == TERTIARY || road_class == RESIDENTIAL",
      "multiply_by": "0.1"
    }
  ],
  "speed": [
    { "if": "true", "limit_to": "4" }
  ]
}